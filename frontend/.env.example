# URL base de la API del backend
VITE_API_URL=http://localhost:3000/api

# Client ID de la app de PayPal.
# En desarrollo usa una app de Sandbox (developer.paypal.com -> My Apps & Credentials).
# En produccion se cambia por el Client ID de la app "Live".
# Debe ser el MISMO par de credenciales que el backend: el frontend usa el
# client-id para abrir el popup, el backend usa client-id + client-secret
# para crear y capturar la orden desde el servidor.
VITE_PAYPAL_CLIENT_ID=
